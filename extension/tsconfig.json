{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "outDir": "dist",
    "rootDir": "..",
    "sourceMap": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "types": ["vscode", "node", "react", "react-dom"]
  },
  "include": ["src/**/*", "../schema/**/*"],
  "exclude": ["node_modules", "dist"]
}
